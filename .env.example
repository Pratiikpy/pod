# SoSoValue — a single key, or a comma-separated pool for round-robin +
# failover (the free tier is 20 req/min per key; the 10-coin fan-out needs
# more, so a pool is recommended). SOSOVALUE_API_KEYS takes precedence.
SOSOVALUE_API_KEY=
SOSOVALUE_API_KEYS=
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1

# CoinGecko Demo (free, no card) — powers the social-sentiment source.
# Optional: without it the source works but rate-limits the 10-coin burst.
COINGECKO_API_KEY=

# SoDEX
SODEX_TESTNET_BASE_URL=https://testnet-gw.sodex.dev/api/v1
SODEX_MAINNET_BASE_URL=https://mainnet-gw.sodex.dev/api/v1
SODEX_TESTNET_CHAIN_ID=138565
SODEX_MAINNET_CHAIN_ID=286623
SODEX_PRIVATE_KEY=
SODEX_NETWORK=testnet

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=

# Privy (embedded wallets)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Database — Postgres (Neon/Supabase free tier) for score history + receipts.
DATABASE_URL=
REDIS_URL=

# Smart Contracts (ValueChain testnet)
DEPLOYER_PRIVATE_KEY=
VALUECHAIN_TESTNET_RPC=https://testnet-rpc.valuechain.xyz
REASONING_LOGGER_ADDRESS=0x0723dc7D775864ec08797e84d2A5E068876B221B
SSI_FACTORY_ADDRESS=
POD_VAULT_ADDRESS=

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Misc
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
